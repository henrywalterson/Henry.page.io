<%- include('partials/head') %>

<%- include('partials/nav') %>

<main>

  <!-- ========== HERO ========== -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__tags">
        <span class="pill">[PLACEHOLDER: Tag 1 e.g. Product Design]</span>
        <span class="pill">[PLACEHOLDER: Tag 2 e.g. UX Research]</span>
        <span class="pill">[PLACEHOLDER: Tag 3 e.g. Design Systems]</span>
      </div>
      <h1 class="hero__headline">
        Hi, I'm <span class="text-gradient">[PLACEHOLDER: Your Name]</span> —<br />
        a Product Designer who [PLACEHOLDER: short role description, e.g. turns complexity into clarity].
      </h1>
      <p class="hero__sub">[PLACEHOLDER: One-line positioning — e.g. I design products people actually want to use, with a focus on research-driven decisions and clean execution.]</p>
      <div class="hero__cta">
        <a href="/#projects" class="btn">View my work</a>
        <a href="/#contact" class="btn btn--ghost">Get in touch</a>
      </div>
    </div>
  </section>

  <!-- ========== FEATURED PROJECT ========== -->
  <section class="section featured" id="projects">
    <div class="container">
      <p class="section__label">Featured Project</p>
      <a href="/project/<%= featured.slug %>" class="featured-card">
        <div class="featured-card__image">
          <img src="<%= featured.thumbnailImage %>" alt="<%= featured.title %>" />
        </div>
        <div class="featured-card__body">
          <span class="pill pill--dark"><%= featured.tag %></span>
          <h2 class="featured-card__title"><%= featured.title %></h2>
          <p class="featured-card__desc"><%= featured.description %></p>
          <span class="link-arrow">View case study →</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ========== CASE STUDIES GRID ========== -->
  <section class="section case-studies">
    <div class="container">
      <p class="section__label">Case Studies</p>
      <div class="cards-grid">
        <% projects.forEach(function(p) { %>
        <a href="/project/<%= p.slug %>" class="card">
          <div class="card__image">
            <img src="<%= p.thumbnailImage %>" alt="<%= p.title %>" />
          </div>
          <div class="card__body">
            <span class="pill"><%= p.tag %></span>
            <h3 class="card__title"><%= p.title %></h3>
            <p class="card__desc"><%= p.description %></p>
            <span class="link-arrow">View case study →</span>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ========== ABOUT + EXPERIENCE ========== -->
  <section class="section about-experience" id="about">
    <div class="container about-experience__inner">

      <!-- About (left) -->
      <div class="about-col">
        <p class="section__label">About</p>
        <h2 class="section__title">[PLACEHOLDER: A short heading about yourself]</h2>
        <p>[PLACEHOLDER: 2–3 sentence bio. Who are you, what do you care about, and what makes your design perspective unique? Keep it human and direct — this is the first real thing people learn about you.]</p>
        <p>[PLACEHOLDER: Optional second paragraph — background, hobbies, or what you're working on right now outside of work.]</p>
        <a href="#" class="btn btn--outline" style="margin-top: var(--space-6);">Download Resume</a>
      </div>

      <!-- Divider -->
      <div class="about-experience__divider" aria-hidden="true"></div>

      <!-- Experience (right) -->
      <div class="experience-col">
        <p class="section__label">Experience</p>
        <h2 class="section__title">Where I've worked</h2>
        <div class="timeline">

          <div class="timeline__item">
            <div class="timeline__dot"></div>
            <div class="timeline__content">
              <span class="timeline__dates">[PLACEHOLDER: Jan 2024 – Present]</span>
              <h3 class="timeline__role">[PLACEHOLDER: Senior Product Designer]</h3>
              <p class="timeline__company">[PLACEHOLDER: Company Name]</p>
              <p class="timeline__desc">[PLACEHOLDER: One-line description of your role and impact here.]</p>
            </div>
          </div>

          <div class="timeline__item">
            <div class="timeline__dot"></div>
            <div class="timeline__content">
              <span class="timeline__dates">[PLACEHOLDER: Jun 2022 – Dec 2023]</span>
              <h3 class="timeline__role">[PLACEHOLDER: Product Designer]</h3>
              <p class="timeline__company">[PLACEHOLDER: Company Name]</p>
              <p class="timeline__desc">[PLACEHOLDER: One-line description of your role and impact here.]</p>
            </div>
          </div>

          <div class="timeline__item">
            <div class="timeline__dot"></div>
            <div class="timeline__content">
              <span class="timeline__dates">[PLACEHOLDER: Mar 2021 – May 2022]</span>
              <h3 class="timeline__role">[PLACEHOLDER: Junior UX Designer]</h3>
              <p class="timeline__company">[PLACEHOLDER: Company Name]</p>
              <p class="timeline__desc">[PLACEHOLDER: One-line description of your role and impact here.]</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ========== CONTACT ========== -->
  <section class="section contact" id="contact">
    <div class="container contact__inner">
      <p class="section__label">Contact</p>
      <h2 class="section__title">[PLACEHOLDER: Let's work together / Got a project in mind?]</h2>
      <p class="contact__sub">[PLACEHOLDER: Short invitation text — e.g. I'm open to freelance projects and full-time opportunities. Drop me a message and I'll get back to you within 24 hours.]</p>

      <form class="contact-form" id="contactForm" novalidate>
        <div class="form-group">
          <label for="email">Your email</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required />
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" placeholder="[PLACEHOLDER: Tell me about your project or just say hi…]" required></textarea>
        </div>
        <button type="submit" class="btn" id="submitBtn">Send message</button>
        <p class="form-feedback" id="formFeedback" aria-live="polite"></p>
      </form>
    </div>
  </section>

</main>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
