<%- include('partials/head', { pageTitle: project.title }) %>

<%- include('partials/nav') %>

<main class="project-page">

  <!-- ========== PROJECT NAV ========== -->
  <div class="project-back container">
    <a href="/" class="link-arrow link-arrow--back">← Back to home</a>
  </div>

  <!-- ========== HERO ========== -->
  <section class="project-hero">
    <div class="container project-hero__inner">
      <span class="pill"><%= project.tag %></span>
      <h1 class="project-hero__title"><%= project.title %></h1>
      <p class="project-hero__sub"><%= project.subtitle %></p>
    </div>
    <div class="project-hero__cover">
      <img src="<%= project.coverImage %>" alt="<%= project.title %> cover" />
    </div>
  </section>

  <!-- ========== META GRID ========== -->
  <section class="project-meta">
    <div class="container project-meta__grid">
      <div class="project-meta__cell">
        <p class="project-meta__label">Role</p>
        <p class="project-meta__value"><%= project.meta.role %></p>
      </div>
      <div class="project-meta__cell">
        <p class="project-meta__label">Company / Product</p>
        <p class="project-meta__value"><%= project.meta.company %></p>
      </div>
      <div class="project-meta__cell">
        <p class="project-meta__label">Timeline</p>
        <p class="project-meta__value"><%= project.meta.timeline %></p>
      </div>
      <div class="project-meta__cell">
        <p class="project-meta__label">Tools</p>
        <p class="project-meta__value"><%= project.meta.tools %></p>
      </div>
    </div>
    <div class="container">
      <p class="project-summary"><%= project.summary %></p>
    </div>
  </section>

  <!-- ========== CONTEXT ========== -->
  <section class="project-section">
    <div class="container project-section__inner">
      <h2 class="project-section__heading">Context</h2>
      <p><%= project.context %></p>
    </div>
  </section>

  <!-- ========== THE PROBLEM ========== -->
  <section class="project-section project-section--accent">
    <div class="container project-section__inner">
      <h2 class="project-section__heading">The Problem</h2>
      <p class="project-problem"><%= project.problem %></p>
    </div>
  </section>

  <!-- ========== PROCESS / RESEARCH ========== -->
  <section class="project-section">
    <div class="container project-section__inner">
      <h2 class="project-section__heading">Process &amp; Research</h2>
      <p><%= project.research %></p>
      <div class="project-image">
        <img src="<%= project.researchImage %>" alt="Research and process diagram" />
        <p class="project-image__caption">[PLACEHOLDER: Diagram or process map caption]</p>
      </div>
    </div>
  </section>

  <!-- ========== KEY DECISIONS ========== -->
  <section class="project-section">
    <div class="container">
      <h2 class="project-section__heading">Key Decisions</h2>
      <div class="decisions">
        <% project.decisions.forEach(function(d) { %>
        <div class="decision">
          <div class="decision__header">
            <span class="decision__number"><%= d.number %></span>
            <h3 class="decision__title"><%= d.heading %></h3>
          </div>
          <p class="decision__reasoning"><%= d.reasoning %></p>
          <div class="project-image">
            <img src="<%= d.image %>" alt="<%= d.heading %>" />
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ========== FINAL SCREENS ========== -->
  <section class="project-section">
    <div class="container">
      <h2 class="project-section__heading">Final Screens</h2>
      <div class="screens-gallery">
        <% project.screens.forEach(function(s) { %>
        <figure class="screen">
          <img src="<%= s.image %>" alt="<%= s.caption %>" />
          <figcaption><%= s.caption %></figcaption>
        </figure>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ========== IMPACT (optional) ========== -->
  <% if (project.impact) { %>
  <section class="project-section project-section--accent">
    <div class="container project-section__inner">
      <h2 class="project-section__heading">Result &amp; Impact</h2>
      <div class="impact-grid">
        <% project.impact.metrics.forEach(function(m) { %>
        <div class="impact-metric">
          <span class="impact-metric__value"><%= m.value %></span>
          <span class="impact-metric__label"><%= m.label %></span>
        </div>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- ========== REFLECTION ========== -->
  <section class="project-section">
    <div class="container project-section__inner">
      <h2 class="project-section__heading">Reflection</h2>
      <blockquote class="pullquote"><%= project.reflection.quote %></blockquote>
      <p class="reflection-limitation"><%= project.reflection.limitation %></p>
    </div>
  </section>

  <!-- ========== PROJECT FOOTER CTA ========== -->
  <section class="project-footer-cta">
    <div class="container project-footer-cta__inner">
      <a href="<%= project.behanceUrl %>" class="btn" target="_blank" rel="noopener noreferrer">See full case study on Behance →</a>
      <div class="project-footer-cta__links">
        <a href="/" class="link-arrow link-arrow--back">← All projects</a>
        <% if (next) { %>
        <a href="/project/<%= next.slug %>" class="link-arrow">Next: <%= next.title %> →</a>
        <% } %>
      </div>
    </div>
  </section>

</main>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
