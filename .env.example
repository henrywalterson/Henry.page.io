PORT=3000

# SMTP credentials for Nodemailer
# Option A — Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here

# Option B — Resend / SendGrid: swap host/port/credentials accordingly

# The address that will RECEIVE contact form submissions
CONTACT_RECEIVER=your_email@example.com
